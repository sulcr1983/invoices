# ==========================================
# 天颐发票处理系统 - 配置文件模板
# 复制此文件为 .env 并填写你的配置
# ==========================================

# -------- 百度 OCR 配置（可选）--------
# 不配置时，PDF文件会使用文本提取回退方案
# 在百度AI平台创建应用后获取：
# https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# -------- 发票验真配置（可选）--------
# 验真功能开关（true/false），需要百度API Key才能使用
VERIFY_ENABLED=true
# 每次验真调用费用（元），用于前端费用提示
VERIFY_COST_PER_CALL=0.25

# -------- 企业微信 Webhook 配置（可选）--------
# 企业微信智能表格的 Webhook 推送地址
# 不配置时，跳过推送步骤
WECOM_WEBHOOK_URL=
# Webhook 的 schema 配置（JSON格式，定义字段映射）
# 用于将发票字段映射到企微智能表格的字段ID
WECOM_SCHEMA={}

# -------- 告警配置（可选）--------
ENABLE_ALERT=false
ALERT_WEBHOOK_URL=

# -------- 系统配置（可选）--------
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 数据库超时时间（秒）
SQLITE_TIMEOUT=20
# HTTP请求超时时间（秒）
REQUEST_TIMEOUT=10
# Webhook重试次数
RETRY_MAX_ATTEMPTS=3
# Webhook重试间隔（秒）
RETRY_DELAY_SECONDS=2
# 日志文件最大大小（字节），默认10MB
LOG_MAX_BYTES=10485760
# 日志文件备份数
LOG_BACKUP_COUNT=3
