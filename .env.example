# ==========================================
# 天颐发票处理系统 - 配置文件模板
# 复制此文件为 .env 并填写你的配置
# ==========================================

# -------- 百度 OCR 配置（必填）--------
# 在百度AI平台创建应用后获取：
# https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_APP_ID=你的百度APP_ID
BAIDU_API_KEY=你的百度API_KEY
BAIDU_SECRET_KEY=你的百度SECRET_KEY

# -------- 企业微信 Webhook 配置（可选）--------
# 企业微信智能表格的 Webhook 推送地址
WECOM_WEBHOOK_URL=
# Webhook 的 schema 配置（JSON格式，定义字段映射）
WECOM_SCHEMA={}

# -------- 系统配置（可选）--------
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 数据库超时时间（秒）
SQLITE_TIMEOUT=20
# HTTP请求超时时间（秒）
REQUEST_TIMEOUT=10
# 重试次数
RETRY_MAX_ATTEMPTS=3
# 重试间隔（秒）
RETRY_DELAY_SECONDS=2
